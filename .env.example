# Notion API Configuration
# Get your token from: https://www.notion.so/my-integrations
NOTION_API_TOKEN=your_notion_integration_token_here

# Option A: Single page for "Publish to web" (no GitHub needed)
# Create one Notion page, share → Publish to web, then set its page ID here.
# Each run overwrites this page so the public URL always shows latest news.
NOTION_PUBLIC_PAGE_ID=

# Option B: New page per day in a database (original behavior)
NOTION_NEWS_DB_ID=
NOTION_PARENT_PAGE_ID=2f764c52f737804da953c1eac61d5f16

# Notion Writer skill: when publishing "AI 每日速报" with parent "daily_news",
# new page is created under this page and inserted at top (AI 每日新闻).
NOTION_DAILY_NEWS_PAGE_ID=

# Daily plan (create-daily-page.js): when set, creates a normal page under "Today List" at top.
# Page ID from Notion URL, e.g. Today List: fdd0108b-d4cf-4282-9b91-2fba6999fb8a
NOTION_TODAY_LIST_PAGE_ID=

# When NOTION_TODAY_LIST_PAGE_ID is not set, daily page is created in this database instead.
NOTION_DAILY_DB_ID=

# Optional: when using NOTION_PUBLIC_PAGE_ID, set your Notion public page URL
# so the "view web version" link points to it instead of GitHub.
# NOTION_WEB_URL=https://your-page.notion.site/...

# Optional: directory containing AI_Daily_News_YYYY-MM-DD.html (default: ~/Desktop/ai-news-daily).
# Notion publish uses file:// link to this so you can open the full page locally.
# LOCAL_HTML_DIR=/path/to/ai-news-daily

# Anthropic API Configuration
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here
